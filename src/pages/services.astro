---
import BaseLayout from '../layouts/BaseLayout.astro';
import { bookingYearsText, limitedAvailabilityText } from '../lib/bookingDates';

const servicesPageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': 'https://blushedbrides.com/services#service',
      name: 'Bridal Hair and Makeup Services',
      provider: {
        '@id': 'https://blushedbrides.com/#business',
      },
      serviceType: [
        'Bridal Hair',
        'Bridal Makeup',
        'Bridal Party Hair and Makeup',
        'Bridal Beauty Trial',
      ],
      areaServed: {
        '@type': 'AdministrativeArea',
        name: 'Northern California',
      },
      url: 'https://blushedbrides.com/services',
      offers: {
        '@type': 'OfferCatalog',
        name: 'Bridal Beauty Services',
      },
    },
    {
      '@type': 'CollectionPage',
      '@id': 'https://blushedbrides.com/services#webpage',
      url: 'https://blushedbrides.com/services',
      name: 'Services & Pricing — Blushed Brides',
      isPartOf: {
        '@id': 'https://blushedbrides.com/#website',
      },
      about: {
        '@id': 'https://blushedbrides.com/#business',
      },
      mainEntity: {
        '@id': 'https://blushedbrides.com/services#service',
      },
    },
  ],
};
---

<BaseLayout
  title="Services & Pricing — Blushed Brides"
  description="Bridal hair, bridal makeup, and full bridal party services for Northern California weddings. See what's included and get pricing."
  canonicalUrl="https://blushedbrides.com/services"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(servicesPageSchema)} />
  </Fragment>

  <!-- ─── Nav ─────────────────────────────────────────── -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="Blushed Brides home">Blushed Brides</a>
      <nav aria-label="Main navigation">
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/services" aria-current="page">Services</a></li>
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="/book" class="btn">Book Now</a></li>
        </ul>
      </nav>
      <button class="site-hamburger" id="siteHamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- ─── Mobile Menu ──────────────────────────────────────── -->
  <div class="bb-mobile-overlay" id="bbMobileOverlay" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <button class="bb-mobile-close" id="bbMobileClose" aria-label="Close menu">✕</button>
    <nav>
      <a href="/" class="mob-link"><span class="mob-num">01 /</span>Home</a>
      <a href="/services" class="mob-link"><span class="mob-num">02 /</span>Services</a>
      <a href="/gallery" class="mob-link"><span class="mob-num">03 /</span>Gallery</a>
      <a href="/about" class="mob-link"><span class="mob-num">04 /</span>About</a>
      <a href="/faq" class="mob-link"><span class="mob-num">05 /</span>FAQ</a>
      <a href="/book" class="mob-link mob-cta"><span class="mob-num">→</span>Book Now</a>
    </nav>
    <div class="bb-mobile-footer">Beauty, Remembered.</div>
  </div>
  <script is:inline>
    (function() {
      var hamburger = document.getElementById('siteHamburger');
      var overlay = document.getElementById('bbMobileOverlay');
      var close = document.getElementById('bbMobileClose');
      if (hamburger && overlay && close) {
        hamburger.addEventListener('click', function() {
          overlay.classList.add('open');
          hamburger.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        });
        close.addEventListener('click', function() {
          overlay.classList.remove('open');
          hamburger.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        });
      }
    })();
  </script>

  <!-- ─── Page Intro ────────────────────────────────────── -->
  <section class="page-intro">
    <div class="container page-intro-inner">
      <div class="page-intro-left">
        <p class="eyebrow reveal-text">What Blushed Brides Offers</p>
        <h1 class="page-intro-heading">
          <span class="reveal-text">Services</span>
          <em class="reveal-text-delay">&amp; Pricing</em>
        </h1>
      </div>
      <div class="page-intro-right reveal-text-delay-2">
        <p class="page-intro-sub">Everything from a solo bridal look to the whole party — handled from first look to last dance.</p>
        <nav class="services-jump-nav" aria-label="Jump to service">
          <a href="#hair">01 — Hair</a>
          <a href="#makeup">02 — Makeup</a>
          <a href="#party">03 — Party</a>
        </nav>
      </div>
    </div>
  </section>

  <!-- ─── Stamps ───────────────────────────────────────── -->
  <section class="stamps-section">
    <div class="container stamps-row fade-up">

      <!-- Stamp 1: Response Time -->
      <div class="stamp stamp--tilt-left" aria-label="Response time: within 48 hours">
        <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="100" cy="100" r="93" fill="none" stroke="currentColor" stroke-width="2"/>
          <circle cx="100" cy="100" r="79" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3.5 3" opacity="0.6"/>
          <path id="s1top" d="M 14,100 A 86,86 0 0,1 186,100" fill="none"/>
          <text font-family="DM Sans, sans-serif" font-size="11" letter-spacing="3" fill="currentColor" font-weight="500">
            <textPath href="#s1top" startOffset="50%" text-anchor="middle">RESPONSE TIME</textPath>
          </text>
          <path id="s1bot" d="M 16,104 A 86,86 0 0,0 184,104" fill="none"/>
          <text font-family="DM Sans, sans-serif" font-size="9" letter-spacing="2" fill="currentColor" font-weight="400" opacity="0.65">
            <textPath href="#s1bot" startOffset="50%" text-anchor="middle">✦ BLUSHED BRIDES ✦</textPath>
          </text>
          <text x="100" y="94" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="16" font-weight="700" font-style="italic" fill="currentColor">Within</text>
          <text x="100" y="115" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="16" font-weight="700" font-style="italic" fill="currentColor">48 Hours</text>
          <line x1="100" y1="5"   x2="100" y2="14"  stroke="currentColor" stroke-width="2"/>
          <line x1="100" y1="186" x2="100" y2="195" stroke="currentColor" stroke-width="2"/>
          <line x1="5"   y1="100" x2="14"  y2="100" stroke="currentColor" stroke-width="2"/>
          <line x1="186" y1="100" x2="195" y2="100" stroke="currentColor" stroke-width="2"/>
        </svg>
      </div>

      <!-- Stamp 2: Service Area -->
      <div class="stamp stamp--tilt-right" aria-label="Service area: Northern California, on location">
        <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="100" cy="100" r="93" fill="none" stroke="currentColor" stroke-width="2"/>
          <circle cx="100" cy="100" r="79" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3.5 3" opacity="0.6"/>
          <path id="s2top" d="M 14,100 A 86,86 0 0,1 186,100" fill="none"/>
          <text font-family="DM Sans, sans-serif" font-size="11" letter-spacing="3" fill="currentColor" font-weight="500">
            <textPath href="#s2top" startOffset="50%" text-anchor="middle">SERVICE AREA</textPath>
          </text>
          <path id="s2bot" d="M 16,104 A 86,86 0 0,0 184,104" fill="none"/>
          <text font-family="DM Sans, sans-serif" font-size="9" letter-spacing="2" fill="currentColor" font-weight="400" opacity="0.65">
            <textPath href="#s2bot" startOffset="50%" text-anchor="middle">✦ ON LOCATION ✦</textPath>
          </text>
          <text x="100" y="94" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="15" font-weight="700" font-style="italic" fill="currentColor">Northern</text>
          <text x="100" y="115" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="15" font-weight="700" font-style="italic" fill="currentColor">California</text>
          <line x1="100" y1="5"   x2="100" y2="14"  stroke="currentColor" stroke-width="2"/>
          <line x1="100" y1="186" x2="100" y2="195" stroke="currentColor" stroke-width="2"/>
          <line x1="5"   y1="100" x2="14"  y2="100" stroke="currentColor" stroke-width="2"/>
          <line x1="186" y1="100" x2="195" y2="100" stroke="currentColor" stroke-width="2"/>
        </svg>
      </div>

      <!-- Stamp 3: Always Included -->
      <div class="stamp stamp--tilt-slight" aria-label="Always included: custom beauty timeline">
        <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="100" cy="100" r="93" fill="none" stroke="currentColor" stroke-width="2"/>
          <circle cx="100" cy="100" r="79" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3.5 3" opacity="0.6"/>
          <path id="s3top" d="M 14,100 A 86,86 0 0,1 186,100" fill="none"/>
          <text font-family="DM Sans, sans-serif" font-size="10" letter-spacing="2.5" fill="currentColor" font-weight="500">
            <textPath href="#s3top" startOffset="50%" text-anchor="middle">ALWAYS INCLUDED</textPath>
          </text>
          <path id="s3bot" d="M 16,104 A 86,86 0 0,0 184,104" fill="none"/>
          <text font-family="DM Sans, sans-serif" font-size="9" letter-spacing="2" fill="currentColor" font-weight="400" opacity="0.65">
            <textPath href="#s3bot" startOffset="50%" text-anchor="middle">✦ EVERY BOOKING ✦</textPath>
          </text>
          <text x="100" y="94" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="15" font-weight="700" font-style="italic" fill="currentColor">Beauty</text>
          <text x="100" y="115" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="15" font-weight="700" font-style="italic" fill="currentColor">Timeline</text>
          <line x1="100" y1="5"   x2="100" y2="14"  stroke="currentColor" stroke-width="2"/>
          <line x1="100" y1="186" x2="100" y2="195" stroke="currentColor" stroke-width="2"/>
          <line x1="5"   y1="100" x2="14"  y2="100" stroke="currentColor" stroke-width="2"/>
          <line x1="186" y1="100" x2="195" y2="100" stroke="currentColor" stroke-width="2"/>
        </svg>
      </div>

    </div>
  </section>

  <!-- ─── Ticker ───────────────────────────────────────── -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      <span class="ticker-item">Bridal Hair &amp; Makeup</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Northern California</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Trial Appointments Available</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">{bookingYearsText}</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Airbrush Foundation</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Bridal Parties Welcome</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">On-Location Available</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Bridal Hair &amp; Makeup</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Northern California</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Trial Appointments Available</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">{bookingYearsText}</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Airbrush Foundation</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Bridal Parties Welcome</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">On-Location Available</span><span class="ticker-sep">✦</span>
    </div>
  </div>

  <!-- ─── Service 01: Bridal Hair ──────────────────────── -->
  <article id="hair" class="service">

    <div class="service-image">
      <!-- Drop photo at: public/images/service-hair-detail.jpg -->
      <div class="service-img-ph" style="--ph-from: #F0D4DC; --ph-to: #C97B8F;" aria-hidden="true"></div>
      <div class="service-image-label">
        <span class="service-num">01</span>
        <span class="service-name-tag">Bridal Hair</span>
      </div>
    </div>

    <div class="container service-body fade-up">
      <div class="service-body-left">
        <h2 class="service-heading">Bridal<br>Hair</h2>
        <p class="service-desc">
          Updos, soft waves, braids, half-up — every style is built to last from first look to the final song. Your artist works with your natural texture and your vision, not against either.
        </p>
        <a href="/book" class="service-cta">Reserve your date &rarr;</a>
      </div>
      <div class="service-body-right">
        <div class="includes-block">
          <p class="includes-label">What's included</p>
          <ul class="includes-list">
            <li>Consultation &amp; detailed style planning</li>
            <li>Day-of styling (up to 90 minutes)</li>
            <li>Veil &amp; accessory placement</li>
            <li>Humidity-resistant finishing products</li>
            <li>Touch-up kit + extra pins to keep</li>
            <li>Trial session available (separate booking)</li>
          </ul>
        </div>
        <div class="pricing-block">
          <div class="pricing-row">
            <span>Bridal Hair</span>
            <span class="price">Starting at $___</span>
          </div>
          <div class="pricing-row">
            <span>Trial Session</span>
            <span class="price">$___</span>
          </div>
        </div>
      </div>
    </div>

  </article>

  <!-- ─── Service 02: Bridal Makeup ────────────────────── -->
  <article id="makeup" class="service">

    <div class="service-image">
      <!-- Drop photo at: public/images/service-makeup-detail.jpg -->
      <div class="service-img-ph" style="--ph-from: #d4a0af; --ph-to: #8B4A5C;" aria-hidden="true"></div>
      <div class="service-image-label">
        <span class="service-num">02</span>
        <span class="service-name-tag">Bridal Makeup</span>
      </div>
    </div>

    <div class="container service-body fade-up">
      <div class="service-body-left">
        <h2 class="service-heading">Bridal<br>Makeup</h2>
        <p class="service-desc">
          Flawless and camera-ready, but still unmistakably you. Airbrush foundation available for an all-day finish that photographs beautifully under any light.
        </p>
        <a href="/book" class="service-cta">Reserve your date &rarr;</a>
      </div>
      <div class="service-body-right">
        <div class="includes-block">
          <p class="includes-label">What's included</p>
          <ul class="includes-list">
            <li>Skin prep + primer</li>
            <li>Custom airbrush or traditional application</li>
            <li>Long-wear, photography-ready formulas</li>
            <li>False lashes (included)</li>
            <li>Lip color touch-up kit to keep</li>
            <li>Trial session available (separate booking)</li>
          </ul>
        </div>
        <div class="pricing-block">
          <div class="pricing-row">
            <span>Bridal Makeup</span>
            <span class="price">Starting at $___</span>
          </div>
          <div class="pricing-row">
            <span>Trial Session</span>
            <span class="price">$___</span>
          </div>
          <div class="pricing-row pricing-featured">
            <span>Hair + Makeup Bundle</span>
            <span class="price">Starting at $___</span>
          </div>
        </div>
      </div>
    </div>

  </article>

  <!-- ─── Service 03: Bridal Party ─────────────────────── -->
  <article id="party" class="service">

    <div class="service-image">
      <!-- Drop photo at: public/images/service-party-detail.jpg -->
      <div class="service-img-ph" style="--ph-from: #e8c4ce; --ph-to: #a05870;" aria-hidden="true"></div>
      <div class="service-image-label">
        <span class="service-num">03</span>
        <span class="service-name-tag">Bridal Party</span>
      </div>
    </div>

    <div class="container service-body fade-up">
      <div class="service-body-left">
        <h2 class="service-heading">Bridal<br>Party</h2>
        <p class="service-desc">
          The whole morning, coordinated. Our team handles the beauty schedule so everyone is camera-ready before the ceremony — no stress, no rushing, no one left out.
        </p>
        <a href="/book" class="service-cta">Get a party quote &rarr;</a>
      </div>
      <div class="service-body-right">
        <div class="includes-block">
          <p class="includes-label">What's included</p>
          <ul class="includes-list">
            <li>Bridesmaid hair &amp; makeup</li>
            <li>Mother of the Bride / Groom services</li>
            <li>Flower girl styling</li>
            <li>Coordinated call time scheduling</li>
            <li>Consistent, cohesive look across the party</li>
            <li>Minimum booking may apply</li>
          </ul>
        </div>
        <div class="pricing-block">
          <div class="pricing-row">
            <span>Bridesmaid Hair</span>
            <span class="price">Starting at $___</span>
          </div>
          <div class="pricing-row">
            <span>Bridesmaid Makeup</span>
            <span class="price">Starting at $___</span>
          </div>
          <div class="pricing-row">
            <span>MOB / MOG</span>
            <span class="price">Starting at $___</span>
          </div>
        </div>
      </div>
    </div>

  </article>

  <!-- ─── How Booking Works ─────────────────────────────── -->
  <section class="how-it-works" id="process">
    <div class="container">
      <div class="hiw-header fade-up">
        <p class="eyebrow">The Process</p>
        <h2>Simple from start to <em>I do.</em></h2>
      </div>
      <div class="hiw-steps fade-up">
        <div class="hiw-step">
          <span class="hiw-num">01</span>
          <h3>Reach out</h3>
          <p>Fill out the inquiry form with your date, location, and party size. Our team follows up within 48 hours.</p>
        </div>
        <div class="hiw-step">
          <span class="hiw-num">02</span>
          <h3>Book a trial</h3>
          <p>Meet in person, test your look, and lock in every detail so the morning of is calm and perfect.</p>
        </div>
        <div class="hiw-step">
          <span class="hiw-num">03</span>
          <h3>Wedding day</h3>
          <p>Your artist arrives on time, ready to work. You get to focus on getting married.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Quick Answers ─────────────────────────────────── -->
  <section class="quick-answers">
    <div class="container quick-answers-inner fade-up">
      <div class="quick-answers-heading">
        <p class="eyebrow">Before You Inquire</p>
        <h2>A few things brides always ask.</h2>
        <a href="/faq" class="qa-more">See all FAQs &rarr;</a>
      </div>
      <div class="qa-list">
        <div class="qa-row">
          <h3 class="qa-question">Do I need a full party to book?</h3>
          <p class="qa-answer">No. We work with solo brides just as often as full wedding parties. Reach out and we'll let you know what's available for your date.</p>
        </div>
        <div class="qa-row">
          <h3 class="qa-question">When does the timeline get locked in?</h3>
          <p class="qa-answer">After booking, we build a beauty schedule around your ceremony, first look, and party size — so everyone is ready without the rush.</p>
        </div>
        <div class="qa-row">
          <h3 class="qa-question">Do you travel to the venue?</h3>
          <p class="qa-answer">Yes. We come to you — getting ready suite, hotel room, or wherever the morning happens. Travel details are sorted at booking.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Final CTA ─────────────────────────────────────── -->
  <section class="final-cta">
    <div class="container">
      <div class="final-cta-inner fade-up">
        <p class="eyebrow light">Ready when you are</p>
        <h2>Your date might still be available.</h2>
        <p class="final-cta-sub">Spots fill fast — especially May through October.<br>Let's find out if yours is open.</p>
        <a href="/book" class="btn btn-light">Let's talk about your day &rarr;</a>
        <p class="final-avail">
          <span class="avail-dot" aria-hidden="true"></span>
          {limitedAvailabilityText}
        </p>
      </div>
    </div>
  </section>

  <!-- ─── Footer ────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <p class="footer-logo">Blushed Brides</p>
        <p class="footer-tagline">Bridal Hair &amp; Makeup — Northern California</p>
      </div>
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="/services">Services</a>
        <a href="/gallery">Gallery</a>
        <a href="/about">About</a>
        <a href="/faq">FAQ</a>
        <a href="/blog">Blog</a>
        <a href="/book" class="footer-book">Book Now</a>
      </nav>
      <div class="footer-right">
        <p class="footer-copy">&copy; {new Date().getFullYear()} Blushed Brides. All rights reserved.</p>
        <a href="/careers" class="footer-join">Join Our Team &rarr;</a>
      </div>
    </div>
  </footer>

</BaseLayout>

<style is:global>

  /* ─── Header ─────────────────────────────────────────── */
  .site-header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding-block: 1.25rem;
    background-color: rgba(250, 248, 246, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--blush-light);
  }
  .header-inner { display: flex; align-items: center; justify-content: space-between; }
  .logo { font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 700; color: var(--ink); text-decoration: none; }
  .nav-links { display: flex; align-items: center; gap: 2.5rem; list-style: none; }
  .nav-links a { font-family: var(--font-body); font-size: var(--text-sm); letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink); text-decoration: none; transition: color 0.2s ease; }
  .nav-links a:hover, .nav-links a[aria-current="page"] { color: var(--blush); }
  .nav-links .btn { font-size: var(--text-xs); padding: 0.6rem 1.4rem; color: #fff; }
  .nav-links .btn:hover { color: #fff; }

  /* ─── Page Intro ─────────────────────────────────────── */
  .page-intro {
    padding-top: 9rem;
    padding-bottom: 4rem;
    background-color: var(--off-white);
    border-bottom: 1px solid var(--blush-light);
  }
  .page-intro-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
  }
  .eyebrow {
    font-family: var(--font-body); font-size: var(--text-xs);
    font-weight: 500; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--blush);
    margin-bottom: 0.75rem; display: block;
  }
  .eyebrow.light { color: var(--blush-light); }
  .page-intro-heading {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 9vw, 7.5rem);
    font-weight: 700;
    line-height: 0.9;

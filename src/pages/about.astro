---
import BaseLayout from '../layouts/BaseLayout.astro';
import { bookingYearsText, limitedAvailabilityText } from '../lib/bookingDates';

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://blushedbrides.com/about#webpage',
  url: 'https://blushedbrides.com/about',
  name: 'About Blushed Brides — Bridal Hair & Makeup',
  description: 'Meet Blushed Brides and learn the bridal hair and makeup approach for Northern California weddings.',
  isPartOf: {
    '@id': 'https://blushedbrides.com/#website',
  },
  about: {
    '@id': 'https://blushedbrides.com/#business',
  },
};
---

<BaseLayout
  title="About Blushed Brides — Bridal Hair & Makeup"
  description="Meet Blushed Brides. Learn our approach, what to expect, and how to book bridal hair and makeup in Northern California."
  canonicalUrl="https://blushedbrides.com/about"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} is:inline />
  </Fragment>

  <header class="site-header">
    <nav class="nav-inner">
      <a href="/" class="nav-logo">Blushed Brides</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/about" class="active">About</a></li>
        <li><a href="/faq">FAQ</a></li>
        <li><a href="/book" class="nav-cta">Book Now</a></li>
      </ul>
      <button class="site-hamburger" id="siteHamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </nav>
  </header>

  <!-- ─── Mobile Menu ──────────────────────────────────────── -->
  <div class="bb-mobile-overlay" id="bbMobileOverlay" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <button class="bb-mobile-close" id="bbMobileClose" aria-label="Close menu">✕</button>
    <nav>
      <a href="/" class="mob-link"><span class="mob-num">01 /</span>Home</a>
      <a href="/services" class="mob-link"><span class="mob-num">02 /</span>Services</a>
      <a href="/gallery" class="mob-link"><span class="mob-num">03 /</span>Gallery</a>
      <a href="/about" class="mob-link"><span class="mob-num">04 /</span>About</a>
      <a href="/faq" class="mob-link"><span class="mob-num">05 /</span>FAQ</a>
      <a href="/book" class="mob-link mob-cta"><span class="mob-num">→</span>Book Now</a>
    </nav>
    <div class="bb-mobile-footer">Beauty, Remembered.</div>
  </div>
  <script is:inline>
    (function() {
      var hamburger = document.getElementById('siteHamburger');
      var overlay = document.getElementById('bbMobileOverlay');
      var close = document.getElementById('bbMobileClose');
      if (hamburger && overlay && close) {
        hamburger.addEventListener('click', function() {
          overlay.classList.add('open');
          hamburger.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        });
        close.addEventListener('click', function() {
          overlay.classList.remove('open');
          hamburger.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        });
      }
    })();
  </script>

  <main>

    <!-- ─── Hero ──────────────────────────────────────────── -->
    <section class="about-hero">
      <p class="eyebrow reveal-text">About Blushed Brides</p>
      <h1 class="about-heading">
        <span class="reveal-text">A team built for</span>
        <em class="reveal-text-delay">calm wedding mornings.</em>
      </h1>
      <p class="about-sub fade-up">
        You are not booking "just hair and makeup." You are booking confidence,
        timing support, and artists who know how to keep your morning smooth
        from the first pin to the last touch-up.
      </p>
      <div class="hero-actions fade-up">
        <a href="/book" class="btn">Check Your Date &rarr;</a>
        <p class="avail-note">
          <span class="avail-dot" aria-hidden="true"></span>
          {limitedAvailabilityText}
        </p>
      </div>
    </section>

    <!-- ─── Approach ──────────────────────────────────────── -->
    <section class="about-approach">
      <div class="approach-inner reveal-block">
        <div class="approach-copy">
          <p class="eyebrow reveal-child">Our Approach</p>
          <h2 class="reveal-child">Editorial standards.<br>Real wedding energy.</h2>
          <p class="reveal-child">
            We blend elevated artistry with practical on-location execution.
            Polished looks that hold up in person, on camera, and through a
            full wedding day timeline.
          </p>
          <p class="reveal-child">
            Every bride gets a custom plan. We shape your look around your
            features, your dress, your venue, and the way you want to feel
            walking down the aisle.
          </p>
        </div>
        <div class="approach-reasons reveal-child">
          <p class="reasons-label">Why brides choose us</p>
          <div class="reason-item">
            <span class="reason-num">01</span>
            <p>Thoughtful prep and timeline support before wedding day</p>
          </div>
          <div class="reason-item">
            <span class="reason-num">02</span>
            <p>Skin-first makeup and long-wear styling that still feels like you</p>
          </div>
          <div class="reason-item">
            <span class="reason-num">03</span>
            <p>Calm, organized artists who keep your morning moving</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Process ───────────────────────────────────────── -->
    <section class="about-process">
      <div class="process-inner">
        <p class="eyebrow fade-up">How booking works</p>
        <h2 class="process-heading fade-up">Simple steps,<br>clear expectations.</h2>
        <div class="process-steps">
          <article class="process-card fade-up">
            <p class="step-label">Step 1</p>
            <h3>Send your date</h3>
            <p>Tell us your date, location, and service count. We confirm availability and fit.</p>
          </article>
          <div class="process-divider" aria-hidden="true"></div>
          <article class="process-card fade-up">
            <p class="step-label">Step 2</p>
            <h3>Choose your package</h3>
            <p>We map your best service setup and share pricing with no guesswork.</p>
          </article>
          <div class="process-divider" aria-hidden="true"></div>
          <article class="process-card fade-up">
            <p class="step-label">Step 3</p>
            <h3>Lock it in</h3>
            <p>Secure your date, then we guide prep details so wedding morning feels easy.</p>
          </article>
        </div>
        <p class="process-note fade-up">{bookingYearsText}</p>
      </div>
    </section>

    <!-- ─── CTA ───────────────────────────────────────────── -->
    <section class="about-cta">
      <div class="about-cta-inner reveal-block">
        <p class="eyebrow reveal-child">Ready for yours?</p>
        <h2 class="reveal-child">If your date is still open,<br>we should talk now.</h2>
        <p class="cta-sub reveal-child">Prime dates move quickly, especially spring through fall weekends.</p>
        <div class="cta-actions reveal-child">
          <a href="/book" class="btn">Book a Consultation &rarr;</a>
          <a href="/services" class="btn btn-outline">See Services</a>
        </div>
      </div>
    </section>

    <!-- ─── Footer ────────────────────────────────────────── -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <p class="footer-logo">Blushed Brides</p>
          <p class="footer-tagline">Bridal Hair &amp; Makeup — Northern California</p>
        </div>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="/services">Services</a>
          <a href="/gallery">Gallery</a>
          <a href="/about">About</a>
          <a href="/faq">FAQ</a>
          <a href="/careers">Join Our Team</a>
          <a href="/book" class="footer-book">Book Now</a>
        </nav>
        <div class="footer-right">
          <div class="footer-socials">
            <a href="https://www.instagram.com/blushed_brides/" target="_blank" rel="noopener noreferrer" class="footer-social" aria-label="Blushed Brides on Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="https://www.tiktok.com/@blushed.brides" target="_blank" rel="noopener noreferrer" class="footer-social" aria-label="Blushed Brides on TikTok">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.25 8.25 0 004.83 1.56V6.79a4.85 4.85 0 01-1.06-.1z"/></svg>
            </a>
            <a href="https://www.facebook.com/blushedbrides" target="_blank" rel="noopener noreferrer" class="footer-social" aria-label="Blushed Brides on Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
          </div>
          <p class="footer-copy">&copy; {new Date().getFullYear()} Blushed Brides. All rights reserved.</p>
        </div>
      </div>
    </footer>

  </main>

</BaseLayout>

<style>
/* ─── Header ─────────────────────────────────────────────── */
.site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 1.25rem var(--gutter);
  transition: background 0.3s, backdrop-filter 0.3s;
}
.site-header--scrolled {
  background: rgba(250, 246, 242, 0.9);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(212, 137, 154, 0.15);
}
.nav-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-logo {
  font-family: var(--font-heading);
  font-size: var(--text-xl);
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--ink);
  text-decoration: none;
}
.nav-links {
  display: flex;
  gap: 2rem;
  list-style: none;
}
.nav-links a {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  opacity: 0.65;
  transition: opacity 0.2s;
}
.nav-links a:hover,
.nav-links a.active { opacity: 1; }
.nav-cta {
  background: var(--blush-dark);
  color: var(--off-white) !important;
  opacity: 1 !important;
  padding: 0.5rem 1.25rem;
  border-radius: 2px;
}

/* ─── Hero ───────────────────────────────────────────────── */
.about-hero {
  padding-top: calc(var(--space-2xl) + 1rem);
  padding-bottom: var(--space-xl);
  padding-left: var(--gutter);
  padding-right: var(--gutter);
  max-width: var(--max-width);
  margin: 0 auto;
}
.eyebrow {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--blush-dark);
  margin-bottom: 1rem;
}
.about-heading {
  font-family: var(--font-heading);
  font-size: clamp(3rem, 7vw, 5.5rem);
  font-weight: 600;
  line-height: 1.05;
  letter-spacing: 0.01em;
  color: var(--ink);
  margin-bottom: 1.75rem;
}
.about-heading span { display: block; }
.about-heading em {
  display: block;
  font-style: italic;
  color: var(--blush-dark);
}
.about-sub {
  max-width: 52ch;
  font-size: var(--text-lg);
  line-height: 1.85;
  color: var(--ink);
  opacity: 0.75;
  margin-bottom: 2rem;
}
.hero-actions {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.avail-note {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--taupe);
}
.avail-dot {
  width: 0.5rem;
  height: 0.5rem;
  border-radius: 50%;
  background: var(--blush);
  animation: pulseDot 2.2s ease-out infinite;
  flex-shrink: 0;
}
@keyframes pulseDot {
  0%   { box-shadow: 0 0 0 0 rgba(212, 137, 154, 0.5); }
  70%  { box-shadow: 0 0 0 8px rgba(212, 137, 154, 0); }
  100% { box-shadow: 0 0 0 0 rgba(212, 137, 154, 0); }
}

/* ─── Approach ───────────────────────────────────────────── */
.about-approach {
  border-top: 1px solid rgba(212, 137, 154, 0.18);
  padding-top: var(--space-xl);
  padding-bottom: var(--space-xl);
  padding-left: var(--gutter);
  padding-right: var(--gutter);
}
.approach-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: clamp(2rem, 5vw, 5rem);
  align-items: start;
}
.approach-copy h2 {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4.5vw, 3.5rem);
  font-weight: 600;
  line-height: 1.1;
  margin-bottom: 1.25rem;
  color: var(--ink);
}
.approach-copy p {
  font-size: var(--text-base);
  line-height: 1.85;
  color: var(--ink);
  opacity: 0.75;
  max-width: 50ch;
  margin-bottom: 0.9rem;
}
.approach-reasons {
  border: 1px solid rgba(212, 137, 154, 0.22);
  border-radius: 2px;
  padding: 1.5rem;
  background: rgba(255, 255, 255, 0.5);
}
.reasons-label {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--blush-dark);
  margin-bottom: 1rem;
}
.reason-item {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 0.85rem;
  padding: 0.9rem 0;
  border-top: 1px solid rgba(212, 137, 154, 0.15);
  align-items: start;
}
.reason-num {
  font-family: var(--font-heading);
  font-size: var(--text-xs);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--blush-dark);
  padding-top: 0.15rem;
}
.reason-item p {
  font-size: var(--text-sm);
  line-height: 1.7;
  color: var(--ink);
  opacity: 0.8;
}

/* ─── Process ────────────────────────────────────────────── */
.about-process {
  padding-top: var(--space-xl);
  padding-bottom: var(--space-xl);
  padding-left: var(--gutter);
  padding-right: var(--gutter);
  background: linear-gradient(180deg, var(--cream) 0%, var(--off-white) 100%);
}
.process-inner {
  max-width: var(--max-width);
  margin: 0 auto;
}
.process-heading {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4.5vw, 3.5rem);
  font-weight: 600;
  line-height: 1.1;
  color: var(--ink);
  margin-bottom: var(--space-lg);
}
.process-steps {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr;
  gap: 0;
  align-items: start;
  margin-bottom: 2rem;
}
.process-divider {
  width: 1px;
  background: rgba(212, 137, 154, 0.25);
  align-self: stretch;
  margin: 0 clamp(1rem, 3vw, 2.5rem);
}
.process-card {
  padding: 0.25rem 0;
}
.step-label {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--blush-dark);
  margin-bottom: 0.75rem;
}
.process-card h3 {
  font-family: var(--font-heading);
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 0.6rem;
}
.process-card p {
  font-size: var(--text-sm);
  line-height: 1.75;
  color: var(--ink);
  opacity: 0.7;
}
.process-note {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--taupe);
}

/* ─── CTA ────────────────────────────────────────────────── */
.about-cta {
  padding-top: var(--space-xl);
  padding-bottom: var(--space-xl);
  padding-left: var(--gutter);
  padding-right: var(--gutter);
}
.about-cta-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  text-align: center;
  border: 1px solid rgba(212, 137, 154, 0.2);
  border-radius: 2px;
  padding: clamp(2rem, 5vw, 4rem);
  background: linear-gradient(180deg, var(--off-white), var(--cream));
}
.about-cta-inner h2 {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 600;
  line-height: 1.1;
  color: var(--ink);
  margin-bottom: 0.85rem;
}
.cta-sub {
  font-size: var(--text-base);
  line-height: 1.7;
  color: var(--ink);
  opacity: 0.65;
  margin-bottom: 2rem;
}
.cta-actions {
  display: inline-flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
}

/* ─── Footer ─────────────────────────────────────────────── */
.site-footer {
  background: var(--ink);
  border-top: 1px solid rgba(212, 137, 154, 0.15);
  padding: var(--space-xl) var(--gutter) var(--space-lg);
}
.footer-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  text-align: center;
}
.footer-brand {
  font-family: var(--font-heading);
  font-size: var(--text-2xl);
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--off-white);
  margin-bottom: 0.5rem;
}
.footer-sub {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--taupe);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: var(--space-md);
}
.footer-nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1.5rem;
  margin-bottom: var(--space-md);
}
.footer-nav a {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--taupe);
  text-decoration: none;
  transition: color 0.2s;
}
.footer-nav a:hover { color: var(--blush); }
.footer-copy {
  font-size: var(--text-xs);
  color: rgba(158, 144, 136, 0.5);
}

/* ─── Responsive ─────────────────────────────────────────── */
@media (max-width: 768px) {
  .nav-links { display: none; }
}
@media (max-width: 800px) {
  .approach-inner {
    grid-template-columns: 1fr;
  }
  .process-steps {
    grid-template-columns: 1fr;
  }
  .process-divider {
    width: 100%;
    height: 1px;
    margin: 1.5rem 0;
  }
  .hero-actions {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>

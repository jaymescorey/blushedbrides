---
import BaseLayout from '../layouts/BaseLayout.astro';
import { bookingYearsText, limitedAvailabilityText } from '../lib/bookingDates';

const homePageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://blushedbrides.com/#home',
  url: 'https://blushedbrides.com/',
  name: 'Blushed Brides — Bridal Hair & Makeup, Northern California',
  description: 'Bridal hair and makeup for Northern California brides with on-location wedding day beauty services.',
  isPartOf: {
    '@id': 'https://blushedbrides.com/#website',
  },
  about: {
    '@id': 'https://blushedbrides.com/#business',
  },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: 'https://blushedbrides.com/images/og-blushedbrides.jpg',
  },
};
---

<BaseLayout
  title="Blushed Brides — Bridal Hair & Makeup, Northern California"
  description="Bridal hair & makeup for Northern California brides who want to feel like themselves — only more. Book your wedding day artist."
  canonicalUrl="https://blushedbrides.com/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(homePageSchema)} />
  </Fragment>

  <!-- ─── Announcement Bar ────────────────────────────── -->
  <div class="announce-bar" role="banner">
    <div class="announce-inner">
      <span class="announce-dot" aria-hidden="true"></span>
      <span class="announce-label">Fall '26: <span class="announce-urgent">4 Dates Remaining</span> · Spring '27 now booking</span>
    </div>
  </div>

  <!-- ─── Hero ─────────────────────────────────────────── -->
  <section class="hero">
    <div class="dot-field" aria-hidden="true"></div>
    <div class="hairline-v v1" aria-hidden="true"></div>
    <div class="hairline-v v2" aria-hidden="true"></div>
    <div class="sparkle delay-1" style="top: 120px; right: 22%;" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 20 20"><path d="M10 0 L11 9 L20 10 L11 11 L10 20 L9 11 L0 10 L9 9 Z" fill="#c9a14a"/></svg>
    </div>
    <div class="sparkle delay-2" style="bottom: 100px; left: 10%;" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 20 20"><path d="M10 0 L11 9 L20 10 L11 11 L10 20 L9 11 L0 10 L9 9 Z" fill="#6b1a1a"/></svg>
    </div>

    <div class="hero-grid">
      <div class="hero-left">

        <div class="hero-eyebrow-pill reveal in">
          <span class="eyebrow-pulse" aria-hidden="true"></span>
          <span class="hero-mono">Now booking · Fall '26 + Spring '27</span>
        </div>

        <h1 class="hero-headline reveal in delay-1">
          Your wedding day, <em>handled.</em>
        </h1>

        <p class="hero-lede reveal in delay-2">
          On-location bridal hair &amp; makeup in Northern California. Editorial-trained team, calm timelines, camera-calibrated results — so every photo looks like the one you pinned.
        </p>

        <div class="hero-cta-row reveal in delay-3">
          <a href="/book" class="hero-btn-primary">
            <span>Check Your Date</span>
            <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
          <a href="/gallery" class="hero-btn-secondary">See the work <span aria-hidden="true">→</span></a>
        </div>

        <div class="hero-stamps reveal in delay-4">
          <div class="h-stamp h-stamp--a" aria-label="Response: within 48 hours">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="100" cy="100" r="93" fill="none" stroke="currentColor" stroke-width="2"/>
              <circle cx="100" cy="100" r="79" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3.5 3" opacity="0.6"/>
              <path id="hs1top" d="M 18,100 A 82,82 0 0,1 182,100" fill="none"/>
              <text font-family="DM Sans, sans-serif" font-size="10" letter-spacing="2.2" fill="currentColor" font-weight="600">
                <textPath href="#hs1top" startOffset="50%" text-anchor="middle">RESPONSE</textPath>
              </text>
              <path id="hs1bot" d="M 18,103 A 82,82 0 0,0 182,103" fill="none"/>
              <text font-family="DM Sans, sans-serif" font-size="7.5" letter-spacing="1.35" fill="currentColor" font-weight="500" opacity="0.8">
                <textPath href="#hs1bot" startOffset="50%" text-anchor="middle">✦ WITHIN 48 HOURS ✦</textPath>
              </text>
              <text x="100" y="94" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="16" font-weight="700" font-style="italic" fill="currentColor">Within</text>
              <text x="100" y="115" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="16" font-weight="700" font-style="italic" fill="currentColor">48 Hours</text>
              <line x1="100" y1="5"   x2="100" y2="14"  stroke="currentColor" stroke-width="2"/>
              <line x1="100" y1="186" x2="100" y2="195" stroke="currentColor" stroke-width="2"/>
              <line x1="5"   y1="100" x2="14"  y2="100" stroke="currentColor" stroke-width="2"/>
              <line x1="186" y1="100" x2="195" y2="100" stroke="currentColor" stroke-width="2"/>
            </svg>
          </div>
          <div class="h-stamp h-stamp--b" aria-label="Coverage: brides, parties, on-location mornings">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="100" cy="100" r="93" fill="none" stroke="currentColor" stroke-width="2"/>
              <circle cx="100" cy="100" r="79" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3.5 3" opacity="0.6"/>
              <path id="hs2top" d="M 18,100 A 82,82 0 0,1 182,100" fill="none"/>
              <text font-family="DM Sans, sans-serif" font-size="10" letter-spacing="2.1" fill="currentColor" font-weight="600">
                <textPath href="#hs2top" startOffset="50%" text-anchor="middle">COVERAGE</textPath>
              </text>
              <path id="hs2bot" d="M 18,103 A 82,82 0 0,0 182,103" fill="none"/>
              <text font-family="DM Sans, sans-serif" font-size="7.1" letter-spacing="1.15" fill="currentColor" font-weight="500" opacity="0.8">
                <textPath href="#hs2bot" startOffset="50%" text-anchor="middle">✦ BRIDES PARTIES ON-LOCATION ✦</textPath>
              </text>
              <text x="100" y="94" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="15" font-weight="700" font-style="italic" fill="currentColor">Brides +</text>
              <text x="100" y="115" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="15" font-weight="700" font-style="italic" fill="currentColor">Parties</text>
              <line x1="100" y1="5"   x2="100" y2="14"  stroke="currentColor" stroke-width="2"/>
              <line x1="100" y1="186" x2="100" y2="195" stroke="currentColor" stroke-width="2"/>
              <line x1="5"   y1="100" x2="14"  y2="100" stroke="currentColor" stroke-width="2"/>
              <line x1="186" y1="100" x2="195" y2="100" stroke="currentColor" stroke-width="2"/>
            </svg>
          </div>
          <div class="h-stamp h-stamp--c" aria-label="Built in: custom timing and touch-up planning">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="100" cy="100" r="93" fill="none" stroke="currentColor" stroke-width="2"/>
              <circle cx="100" cy="100" r="79" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3.5 3" opacity="0.6"/>
              <path id="hs3top" d="M 18,100 A 82,82 0 0,1 182,100" fill="none"/>
              <text font-family="DM Sans, sans-serif" font-size="9.4" letter-spacing="2.1" fill="currentColor" font-weight="600">
                <textPath href="#hs3top" startOffset="50%" text-anchor="middle">BUILT IN</textPath>
              </text>
              <path id="hs3bot" d="M 18,103 A 82,82 0 0,0 182,103" fill="none"/>
              <text font-family="DM Sans, sans-serif" font-size="6.9" letter-spacing="1.1" fill="currentColor" font-weight="500" opacity="0.8">
                <textPath href="#hs3bot" startOffset="50%" text-anchor="middle">✦ TIMING TOUCH-UPS DETAILS ✦</textPath>
              </text>
              <text x="100" y="94" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="15" font-weight="700" font-style="italic" fill="currentColor">Timing +</text>
              <text x="100" y="115" text-anchor="middle" font-family="Playfair Display, Georgia, serif" font-size="15" font-weight="700" font-style="italic" fill="currentColor">Touch-Ups</text>
              <line x1="100" y1="5"   x2="100" y2="14"  stroke="currentColor" stroke-width="2"/>
              <line x1="100" y1="186" x2="100" y2="195" stroke="currentColor" stroke-width="2"/>
              <line x1="5"   y1="100" x2="14"  y2="100" stroke="currentColor" stroke-width="2"/>
              <line x1="186" y1="100" x2="195" y2="100" stroke="currentColor" stroke-width="2"/>
            </svg>
          </div>
        </div>

        <div class="hero-social reveal in delay-4">
          <div class="hero-stars" aria-label="Five stars">★ ★ ★ ★ ★</div>
          <div class="hero-social-text">
            <strong>4.98 average</strong> across 127 reviews ·
            Featured in <em>Magnolia Rouge</em> &amp; <em>Green Wedding Shoes</em>
          </div>
        </div>

      </div>

      <div class="hero-right">
        <div class="hero-card main" aria-hidden="true">
          <img src="/images/blushed-brides-on-location-bridal-makeup.png" alt="" loading="eager" />
        </div>
        <div class="hero-card accent" aria-hidden="true">
          <img src="/images/blushed-brides-bridal-beauty-wedding-morning.png" alt="" loading="eager" />
        </div>

        <div class="hero-avail">
          <div class="hero-avail-label hero-mono">Availability Alert</div>
          <div class="hero-avail-text">
            <strong>Sept 12, 2026</strong> just opened — a bride's venue change freed up peak fall.
          </div>
        </div>

        <div class="hero-badge">
          <div class="badge-avatars" aria-hidden="true">
            <div class="badge-avatar"></div>
            <div class="badge-avatar"></div>
            <div class="badge-avatar"></div>
          </div>
          <div class="badge-text">
            <strong>400+</strong> brides<br>served since '15
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Scroll Reveal Gallery ──────────────────────────── -->
  <section class="scroll-reveal-wrap" aria-label="Bridal portfolio preview">
    <div class="scroll-reveal-content">
      <div class="sr-grid">
        <!-- Layer 1: Outer edges -->
        <div class="sr-layer">
          <div><img src="/images/blushed-brides-bridal-hair-updo-elegant.jpg" alt="Bridal hair updo" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-bridal-soft-glam-makeup-look.jpg" alt="Soft glam bridal makeup" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-wedding-day-bridal-party-prep.jpg" alt="Bridal party prep" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-bridal-morning-prep-hair-updo.jpg" alt="Morning prep hair updo" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-on-site-bridal-hair-styling.png" alt="On-site hair styling" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-wedding-day-soft-romantic-hair.jpg" alt="Soft romantic wedding hair" loading="lazy" /></div>
        </div>
        <!-- Layer 2: Inner columns -->
        <div class="sr-layer">
          <div><img src="/images/blushed-brides-bridal-party-hair-styling.png" alt="Bridal party hair" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-bride-glam-wedding-makeup.jpg" alt="Glam wedding makeup" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-bridal-hair-makeup-wedding-look.jpg" alt="Wedding hair and makeup" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-bride-airbrush-makeup-wedding.jpg" alt="Airbrush wedding makeup" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-wedding-day-bridal-beauty.jpg" alt="Wedding day bridal beauty" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-on-location-wedding-beauty.jpg" alt="On-location wedding beauty" loading="lazy" /></div>
        </div>
        <!-- Layer 3: Center column top and bottom -->
        <div class="sr-layer">
          <div><img src="/images/blushed-brides-bridal-prep-morning-getting-ready.jpg" alt="Morning bridal prep" loading="lazy" /></div>
          <div><img src="/images/blushed-brides-wedding-morning-bridal-beauty.jpg" alt="Wedding morning beauty" loading="lazy" /></div>
        </div>
        <!-- Center scaler image -->
        <div class="sr-scaler">
          <img src="/images/blushed-brides-bride-natural-glam-makeup.jpg" alt="Bridal natural glam makeup" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <style>
    .scroll-reveal-wrap {
      min-height: 200vh;
      background: var(--blush-light);
    }

    .scroll-reveal-content {
      min-height: 100vh;
      width: 100vw;
      display: flex;
      place-items: center;
      position: sticky;
      top: 0;
      overflow: hidden;
    }

    .sr-grid {
      --gap: clamp(10px, 7.35vw, 80px);
      --container-width: 1600px;
      --offset: 0;

      width: var(--container-width);
      max-width: calc(100% - 4rem);
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      grid-template-rows: repeat(3, auto);
      gap: var(--gap);
      margin: 0 auto;
      align-content: center;
      position: absolute;
      top: 50%;
      left: 50%;
      translate: -50% -50%;
    }

    @media (max-width: 600px) {
      .sr-grid {
        grid-template-columns: repeat(3, 1fr);
        --offset: -1;
        max-width: calc(100% - 2rem);
      }
      .sr-grid > .sr-layer:nth-of-type(1) {
        display: none;
      }
    }

    .sr-grid > .sr-layer {
      display: grid;
      grid-column: 1 / -1;
      grid-row: 1 / -1;
      grid-template-columns: subgrid;
      grid-template-rows: subgrid;
    }

    .sr-grid > .sr-layer:nth-of-type(1) div:nth-of-type(odd) { grid-column: 1; }
    .sr-grid > .sr-layer:nth-of-type(1) div:nth-of-type(even) { grid-column: -2; }

    .sr-grid > .sr-layer:nth-of-type(2) div:nth-of-type(odd) { grid-column: calc(2 + var(--offset)); }
    .sr-grid > .sr-layer:nth-of-type(2) div:nth-of-type(even) { grid-column: calc(-3 - var(--offset)); }

    .sr-grid > .sr-layer:nth-of-type(3) div:first-of-type {
      grid-column: calc(3 + var(--offset));
      grid-row: 1;
    }
    .sr-grid > .sr-layer:nth-of-type(3) div:last-of-type {
      grid-column: calc(3 + var(--offset));
      grid-row: -1;
    }

    .sr-grid img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border-radius: 0.75rem;
    }

    .sr-scaler {
      grid-area: 2 / calc(3 + var(--offset));
      position: relative;
      z-index: 2;
      width: 100%;
      height: 100%;
    }

    .sr-scaler img {
      position: absolute;
      top: 50%;
      left: 50%;
      translate: -50% -50%;
      object-fit: cover;
      border-radius: 0.75rem;
      width: 100%;
      height: 100%;
    }
  </style>

  <script>
    import { animate, scroll, cubicBezier } from 'motion';

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const image = document.querySelector('.sr-scaler img') as any;
      const section = document.querySelector('.scroll-reveal-wrap') as Element;
      const layers = document.querySelectorAll('.sr-grid > .sr-layer');

      if (image && section && layers.length) {
        const naturalWidth = image.offsetWidth;
        const naturalHeight = image.offsetHeight;
        const vw = window.innerWidth;
        const vh = window.innerHeight;

        scroll(
          animate(image, { width: [vw, naturalWidth], height: [vh, naturalHeight] } as any, {
            width: { easing: cubicBezier(0.65, 0, 0.35, 1) },
            height: { easing: cubicBezier(0.42, 0, 0.58, 1) },
          } as any),
          { target: section, offset: ['start 70%', 'end end'] }
        );

        const scaleEasings = [
          cubicBezier(0.42, 0, 0.58, 1),
          cubicBezier(0.76, 0, 0.24, 1),
          cubicBezier(0.87, 0, 0.13, 1),
        ];

        layers.forEach((layer, i) => {
          const endOffset = `${1 - i * 0.05} end`;

          scroll(
            animate(layer as any, { opacity: [0, 0, 1] } as any, { offset: [0, 0.1, 1], easing: cubicBezier(0.61, 1, 0.88, 1) } as any),
            { target: section, offset: ['start 70%', endOffset as any] }
          );

          scroll(
            animate(layer as any, { scale: [0, 0, 1] } as any, { offset: [0, 0.05, 1], easing: scaleEasings[i] } as any),
            { target: section, offset: ['start 70%', endOffset as any] }
          );
        });
      }
    }
  </script>

  <!-- ─── Ticker ───────────────────────────────────────── -->
  <div class="ticker fade-up" aria-hidden="true">
    <div class="ticker-track">
      <span class="ticker-item">Bridal Hair &amp; Makeup</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Northern California</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Trial Appointments Available</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">{bookingYearsText}</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Airbrush Foundation</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Bridal Parties Welcome</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">On-Location Available</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Bridal Hair &amp; Makeup</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Northern California</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Trial Appointments Available</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">{bookingYearsText}</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Airbrush Foundation</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">Bridal Parties Welcome</span><span class="ticker-sep">✦</span>
      <span class="ticker-item">On-Location Available</span><span class="ticker-sep">✦</span>
    </div>
  </div>

  <section class="standards" id="proof">
    <div class="container">
      <div class="standards-left reveal-block">
        <p class="standards-eyebrow reveal-child">The Standard</p>
        <h2 class="standards-heading reveal-child">Pretty is<br>expected.<br><em>Handled</em><br>is what<br>matters.</h2>
      </div>
      <div class="standards-right reveal-block">
        <div class="standard-card reveal-child">
          <div class="standard-card-top">
            <span class="standard-num">01</span>
            <h3>Timing</h3>
          </div>
          <p>Every booking is built around your ceremony time, first look, photographer arrival, and party size. No guessing, no rushing.</p>
        </div>
        <div class="standard-card reveal-child">
          <div class="standard-card-top">
            <span class="standard-num">02</span>
            <h3>Wear</h3>
          </div>
          <p>Long-wear products, touch-up kits, and finishing details built into every service. The look holds from first look to last dance.</p>
        </div>
        <div class="standard-card reveal-child">
          <div class="standard-card-top">
            <span class="standard-num">03</span>
            <h3>Support</h3>
          </div>
          <p>Team coordination for any party size. Calm pace, clean handoffs, and photo-ready results from start to finish.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Type Bridge ─────────────────────────────────────── -->
  <div class="type-bridge reveal-block" aria-hidden="true">
    <span class="bridge-word reveal-child">Hair</span>
    <span class="bridge-sep reveal-child">·</span>
    <span class="bridge-word reveal-child">Makeup</span>
    <span class="bridge-sep reveal-child">·</span>
    <span class="bridge-word reveal-child">Party</span>
  </div>

  <!-- ─── Services Lookbook ─────────────────────────────── -->
  <section class="lookbook">
    <div class="lookbook-inner">

      <div class="lookbook-list reveal-block">
        <div class="lookbook-list-header">
          <p class="lookbook-eyebrow reveal-child">Services</p>
          <h2 class="lookbook-heading reveal-child">Your look.<br><em>Three ways<br>to get there.</em></h2>
          <p class="lookbook-intro reveal-child">Hair. Makeup. The whole room. Built to move on schedule and photograph beautifully.</p>
        </div>
        <div class="lookbook-items">
          <button class="lookbook-item reveal-child active" data-service="hair">
            <span class="lookbook-item-main">
              <span class="lookbook-num">01</span>
              <span class="lookbook-copy">
                <span class="lookbook-name">Bridal Hair</span>
                <span class="lookbook-desc">Soft structure, hold that lasts, finishing details that move naturally in photos.</span>
              </span>
            </span>
            <span class="lookbook-arrow">&rarr;</span>
          </button>
          <button class="lookbook-item reveal-child" data-service="makeup">
            <span class="lookbook-item-main">
              <span class="lookbook-num">02</span>
              <span class="lookbook-copy">
                <span class="lookbook-name">Bridal Makeup</span>
                <span class="lookbook-desc">Skin-forward, structured enough to hold from first look to dance floor.</span>
              </span>
            </span>
            <span class="lookbook-arrow">&rarr;</span>
          </button>
          <button class="lookbook-item reveal-child" data-service="party">
            <span class="lookbook-item-main">
              <span class="lookbook-num">03</span>
              <span class="lookbook-copy">
                <span class="lookbook-name">Bridal Party</span>
                <span class="lookbook-desc">Full room, coordinated. Everyone ready without the pace falling apart.</span>
              </span>
            </span>
            <span class="lookbook-arrow">&rarr;</span>

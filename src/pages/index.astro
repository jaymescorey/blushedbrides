  }
  /* Sliding blush underline — translated from jaymescorey's yellow underline */
  .nav-links a:not(.nav-cta)::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background-color: var(--blush);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .nav-links a:not(.nav-cta):hover { color: var(--blush-dark); }
  .nav-links a:not(.nav-cta):hover::after { transform: scaleX(1); }

  /* CTA — elegant outline with shimmer */
  .nav-cta {
    position: relative !important;
    overflow: hidden !important;
    border: 1px solid var(--blush) !important;
    color: var(--blush-dark) !important;

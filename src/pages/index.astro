    text-transform: none !important;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease !important;
  }
  .nav-cta::before {
    content: '' !important;
    position: absolute !important;
    top: 0 !important;
    left: -75% !important;
    width: 50% !important;
    height: 100% !important;
    background: linear-gradient(105deg, transparent 20%, rgba(255,255,255,0.55) 50%, transparent 80%) !important;
    transform: skewX(-15deg) !important;
    transition: left 0.55s ease !important;
    pointer-events: none !important;
  }
  .nav-cta:hover::before {
    left: 140% !important;
  }
  .nav-cta:hover {
    background-color: var(--blush) !important;
    border-color: var(--blush) !important;
    color: #fff !important;
    transform: none !important;
  }
  .nav-cta::after { display: none !important; }

  /* ─── Announcement Bar ───────────────────────────────── */
  .announce-bar {
    background: rgba(255, 253, 250, 0.97);

<script is:inline>
  // ─── Fade-up on scroll ─────────────────────────────────
  const fadeObserver = new IntersectionObserver((entries) => {
    entries.forEach(el => {
      if (el.isIntersecting) { el.target.classList.add('visible'); fadeObserver.unobserve(el.target); }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.fade-up').forEach(el => fadeObserver.observe(el));

  // ─── Lookbook service selector ─────────────────────────
  const lookbookItems = document.querySelectorAll('.lookbook-item');
  const lookbookPanels = document.querySelectorAll('.lookbook-panel');

  lookbookItems.forEach(item => {
    item.addEventListener('click', () => {
      const target = item.dataset.service;
      lookbookItems.forEach(i => i.classList.remove('active'));
      lookbookPanels.forEach(p => p.classList.remove('active'));
      item.classList.add('active');
      document.querySelector(`.lookbook-panel[data-service="${target}"]`).classList.add('active');
    });
  });

  // ─── Morning Of scrollytelling ─────────────────────────
  const morningSection   = document.querySelector('.morning-of');
  const morningMoments   = document.querySelectorAll('.moment');
  const morningImages    = document.querySelectorAll('.morning-img');
  const morningDots      = document.querySelectorAll('.morning-dot');
  const progressFill     = document.querySelector('.morning-progress-fill');
  const MOMENT_COUNT     = morningMoments.length;

  function setMoment(index) {
    morningMoments.forEach((m, i) => m.classList.toggle('active', i === index));
    morningImages.forEach((img, i) => img.classList.toggle('active', i === index));
    morningDots.forEach((d, i) => d.classList.toggle('active', i === index));
  }

  // Dot nav — jump to moment on click
  morningDots.forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = parseInt(dot.dataset.moment);
      const sectionTop = morningSection.getBoundingClientRect().top + window.scrollY;
      const sectionHeight = morningSection.offsetHeight - window.innerHeight;
      const targetScroll = sectionTop + (idx / MOMENT_COUNT) * sectionHeight;
      window.scrollTo({ top: targetScroll, behavior: 'smooth' });
    });
  });

  window.addEventListener('scroll', () => {
    if (!morningSection) return;
    const rect = morningSection.getBoundingClientRect();
    const sectionHeight = morningSection.offsetHeight - window.innerHeight;
    const scrolled = -rect.top;
    const progress = Math.max(0, Math.min(1, scrolled / sectionHeight));

    if (progressFill) progressFill.style.width = `${progress * 100}%`;

    const rawIndex = progress * MOMENT_COUNT;
    const index = Math.min(Math.floor(rawIndex), MOMENT_COUNT - 1);
    setMoment(index);
  }, { passive: true });
</script>

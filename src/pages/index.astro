    align-items: center;
    gap: 12px;
    animation: floatGentle 6s ease-in-out -3s infinite;
  }
  .badge-avatars { display: flex; }
  .badge-avatar {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--blush-soft), var(--wine));
    border: 2px solid var(--bone-pure);
    margin-left: -8px;
  }
  .badge-avatar:first-child { margin-left: 0; }
  .badge-avatar:nth-child(2) { background: linear-gradient(135deg, var(--gold-soft), var(--rust)); }
  .badge-avatar:nth-child(3) { background: linear-gradient(135deg, var(--blush-soft), var(--oxblood)); }
  .badge-text {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.4;
    color: var(--ink);
  }
  .badge-text strong { font-style: italic; font-weight: 500; }

  /* ─── Ticker ─────────────────────────────────────────── */
  .ticker {
    width: 100%; overflow: hidden;
    background-color: rgba(255, 255, 255, 0.92);
    background-image: var(--texture-pixel-fine);
    background-size: var(--texture-pixel-fine-size);
    background-repeat: repeat;
    border-top: 1px solid var(--blush-light);
    border-bottom: 1px solid var(--blush-light);
    padding-block: 0.85rem;
  }
  .ticker-track {
    display: flex; align-items: center; gap: 1.5rem;
    width: max-content; animation: ticker 28s linear infinite;
  }
  .ticker:hover .ticker-track { animation-play-state: paused; }
  .ticker-item {
    font-family: var(--font-body); font-size: var(--text-xs);
    font-weight: 400; letter-spacing: 0.18em; font-style: italic;
    text-transform: uppercase; color: var(--blush-dark); white-space: nowrap;
  }
  .ticker-sep { color: var(--blush); font-size: 0.5rem; flex-shrink: 0; }

  /* ─── Standards ─────────────────────────────────────── */
  .standards {
    padding-block: var(--space-xl);
    background:
      radial-gradient(circle at top left, rgba(245, 230, 235, 0.56), transparent 28%),
      linear-gradient(180deg, #fffdfb 0%, #f7efec 100%);
    position: relative;
    overflow: hidden;
  }
  .standards .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }
  .standards-left {
    position: sticky;
    top: 6rem;
  }
  .standards-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blush);
    margin-bottom: 1.5rem;
  }
  .standards-heading {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 300;
    line-height: 1.05;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .standards-heading em {
    font-style: italic;
    color: var(--blush);
    font-weight: 400;
  }
  .standards-right {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .standard-card {
    padding: 2.25rem 0;
    border-top: 1px solid rgba(212, 137, 154, 0.2);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .standard-card:last-child {
    border-bottom: 1px solid rgba(212, 137, 154, 0.2);
  }
  .standard-card-top {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }
  .standard-num {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blush);
    flex-shrink: 0;
  }
  .standard-card h3 {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--ink);
    line-height: 1;
  }
  .standard-card p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--taupe);
    font-weight: 400;
    padding-left: calc(var(--text-xs) + 1rem + 4px);
  }

  /* ─── Shared section ─────────────────────────────────── */
  .section-eyebrow {
    font-family: var(--font-body); font-size: var(--text-xs);
    font-weight: 500; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--blush); margin-bottom: 0.75rem;
  }
  .section-eyebrow.light { color: var(--blush-dark); }

  /* ─── Type Bridge ───────────────────────────────────── */
  .type-bridge {
    background-color: var(--cream);
    position: relative;
    overflow: hidden;
    padding-block: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }
  .type-bridge::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--texture-dots-light), var(--texture-pixel-fine);
    background-size: var(--texture-dots-light-size), var(--texture-pixel-fine-size);
    background-repeat: repeat, repeat;
    opacity: 0.22;
    pointer-events: none;
  }
  .bridge-word {
    font-family: var(--font-heading);
    font-size: clamp(0.75rem, 1.4vw, 1.1rem);
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.18em;
    color: var(--taupe);
    line-height: 1;
    position: relative;
    text-transform: none;
  }
  .bridge-sep {
    font-family: var(--font-body);
    font-size: 0.5rem;
    color: var(--blush);
    line-height: 1;
    position: relative;
    opacity: 0.8;
  }

  /* ─── Services Lookbook ──────────────────────────────── */
  .lookbook {
    background-color: var(--cream);
    background-image: var(--texture-pixel-fine);
    background-size: var(--texture-pixel-fine-size);
    background-repeat: repeat;
  }

  .lookbook-inner {
    display: grid;
    grid-template-columns: minmax(22rem, 0.7fr) 1fr;
    min-height: 88vh;
  }

  /* Left dark panel */
  .lookbook-list {
    display: flex;
    flex-direction: column;
    background-color: var(--ink);
    background-image:
      linear-gradient(160deg, rgba(38,24,32,0.97) 0%, rgba(55,30,45,0.99) 100%),
      var(--texture-dots-dark);
    background-size: auto, var(--texture-dots-dark-size);
    background-repeat: no-repeat, repeat;
  }

  .lookbook-list-header {
    padding: 3.5rem 3rem 2.5rem;
    border-bottom: 1px solid rgba(212,137,154,0.15);
  }
  .lookbook-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blush);
    margin-bottom: 1.25rem;
  }
  .lookbook-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 3.5vw, 3.25rem);
    font-weight: 300;
    line-height: 1.05;
    color: var(--cream);
    letter-spacing: 0.01em;
    margin-bottom: 1.25rem;
  }
  .lookbook-heading em {
    font-style: italic;
    color: var(--blush);
    font-weight: 400;
  }
  .lookbook-intro {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--taupe);
  }

  .lookbook-items {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .lookbook-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.75rem 3rem;
    border-bottom: 1px solid rgba(212,137,154,0.12);
    background: transparent;
    cursor: pointer;
    text-align: left;
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }
  .lookbook-item:first-child { border-top: 1px solid rgba(212,137,154,0.12); }
  .lookbook-item:hover { background-color: rgba(212,137,154,0.06); }
  .lookbook-item.active { background-color: rgba(212,137,154,0.10); border-left: 3px solid var(--blush); padding-left: calc(3rem - 3px); }

  .lookbook-item-main {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    flex: 1;
    min-width: 0;
  }
  .lookbook-copy {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }

  .lookbook-num {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--taupe);
    flex-shrink: 0;
    padding-top: 0.35rem;
  }

  .lookbook-name {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2vw, 2rem);
    font-weight: 600;
    color: var(--cream);
    line-height: 1;
    letter-spacing: 0.01em;
  }
  .lookbook-desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--taupe);
  }

  .lookbook-arrow {
    font-size: var(--text-base);
    color: rgba(212,137,154,0.4);
    transition: color 0.25s ease, transform 0.25s ease;
    flex-shrink: 0;
  }
  .lookbook-item.active .lookbook-arrow,
  .lookbook-item:hover .lookbook-arrow {
    color: var(--blush);
    transform: translateX(4px);
  }

  .lookbook-all {
    display: block;
    padding: 1.5rem 3rem;
    border-top: 1px solid rgba(212,137,154,0.15);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--blush);
    text-decoration: none;
    transition: background-color 0.2s ease;
  }
  .lookbook-all:hover { background-color: rgba(212,137,154,0.08); }

  /* Right image stage */
  .lookbook-stage {
    position: relative;
    overflow: hidden;
    min-height: 88vh;
  }

  .lookbook-panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }
  .lookbook-panel.active { opacity: 1; pointer-events: auto; }

  .lookbook-img-placeholder {
    width: 100%;
    height: 88vh;
    background-image:
      var(--texture-dots-light),
      linear-gradient(160deg, var(--ph-from), var(--ph-to));
    background-size: var(--texture-dots-light-size), cover;
    background-repeat: repeat, no-repeat;
    opacity: 0.98;
  }

  .lookbook-img-placeholder img {
    width: 100%; height: 100%; object-fit: cover;
  }

  .lookbook-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 3rem 2.5rem;
    background: linear-gradient(to top, rgba(38,24,32,0.9) 0%, transparent 100%);
    color: #fff;
  }
  .lookbook-caption-kicker {
    display: block;
    margin-bottom: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--blush-light);
  }
  .lookbook-caption h3 {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 600;
    margin-bottom: 0.6rem;
    letter-spacing: 0.01em;
  }
  .lookbook-caption p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: 1.7;
    opacity: 0.82;
    margin-bottom: 1.5rem;
    max-width: 38ch;
  }
  .service-link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blush-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .service-link:hover { color: #fff; }

  /* ─── Experience Intro ──────────────────────────────── */
  .experience-intro {
    padding-block: var(--space-xl);
    background-color: var(--off-white);
    border-top: 1px solid var(--blush-light);
  }
  .experience-intro-inner {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 3rem;
    align-items: start;
  }
  .experience-intro-inner h2 {
    font-family: var(--font-heading); font-size: var(--text-4xl);
    line-height: 1.08; color: var(--ink);
  }
  .experience-intro-copy {
    display: flex; flex-direction: column; gap: 1rem;
  }
  .experience-intro-copy p {
    font-family: var(--font-body); font-size: var(--text-base);
    font-weight: 300; line-height: 1.75; color: #666;
  }
  .experience-points {
    list-style: none; display: grid; gap: 0.8rem;
  }
  .experience-points li {
    padding: 0.9rem 1rem;
    border-left: 2px solid var(--blush);
    background-color: #fff;
    color: #555;
    font-family: var(--font-body); font-size: var(--text-sm); line-height: 1.7;
  }

  /* ─── The Morning Of ─────────────────────────────────── */
  .morning-of { height: 500vh; }

  .morning-sticky {
    position: sticky; top: 0;
    height: 100vh; overflow: hidden;
  }

  .morning-images { position: absolute; inset: 0; }

  .morning-img {
    position: absolute; inset: 0;
    background: var(--wine-deep);
    opacity: 0; transition: opacity 1s ease;
  }
  .morning-img.active { opacity: 1; }
  .morning-img img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  }

  .morning-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(26,26,26,0.2) 0%,
      rgba(26,26,26,0.5) 50%,
      rgba(26,26,26,0.75) 100%
    );
  }

  .morning-content {
    position: absolute; inset: 0; z-index: 2;
    display: flex; align-items: center; justify-content: center;
    text-align: center; padding-inline: var(--gutter);
  }

  .moment {
    position: absolute;
    opacity: 0; transform: translateY(1.5rem);
    transition: opacity 0.7s ease, transform 0.7s ease;
    pointer-events: none;
  }
  .moment.active {
    opacity: 1; transform: translateY(0);
    pointer-events: auto; position: relative;
  }

  .moment-time {
    display: block;
    font-family: var(--font-body); font-size: var(--text-sm);
    font-weight: 500; letter-spacing: 0.25em;
    text-transform: uppercase; color: var(--blush-light);
    margin-bottom: 1.5rem;
  }

  .moment-text {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700; line-height: 1.15;
    letter-spacing: -0.02em; color: #fff;
  }

  .moment-text em {
    font-style: italic; color: var(--blush-light);
  }
  .morning-plan-card {
    position: relative;
    overflow: hidden;
    width: min(25rem, calc(100vw - 2rem));
    padding: 1.2rem;
    border: 1px solid rgba(139, 74, 92, 0.18);
    border-radius: 1.4rem;
    background:
      radial-gradient(circle at top right, rgba(201, 123, 143, 0.14), transparent 34%),
      linear-gradient(180deg, #fffdfc 0%, #f7efec 100%);
    box-shadow: 12px 12px 0 rgba(139, 74, 92, 0.12);
    color: var(--ink);
  }
  .morning-plan-topline {
    margin-bottom: 0.45rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--blush);
  }
  .morning-plan-label {
    margin-bottom: 1rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.7;
    color: #65575c;
  }
  .morning-plan-row {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: 0.9rem;
    padding: 0.8rem 0;
    border-top: 1px solid rgba(139, 74, 92, 0.12);
  }
  .morning-plan-time {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 4.8rem;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    background: rgba(201, 123, 143, 0.12);
    color: var(--blush-dark);
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
  }
  .morning-plan-item {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: #40353a;
  }
  .morning-plan-footnote {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed rgba(139, 74, 92, 0.18);
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8b6b75;
  }

  /* Progress bar */
  .morning-progress-bar {
    position: absolute; bottom: 0; left: 0; right: 0; z-index: 3;
    height: 2px; background-color: rgba(255,255,255,0.15);
  }
  .morning-progress-fill {
    height: 100%; width: 0%;
    background-color: var(--blush);
    transition: width 0.1s linear;
  }

  /* Dot nav */
  .morning-dots {
    position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
    z-index: 3; display: flex; gap: 0.75rem;
  }
  .morning-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background-color: rgba(255,255,255,0.35);
    border: none; cursor: pointer; padding: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }
  .morning-dot.active {
    background-color: var(--blush); transform: scale(1.4);
  }

  /* ─── Gallery Preview ────────────────────────────────── */
  .gallery-preview {
    padding-top: var(--space-xl);
    background-color: var(--off-white);
    background-image: var(--texture-dots-light), var(--texture-pixel-fine);
    background-size: var(--texture-dots-light-size), var(--texture-pixel-fine-size);
    background-repeat: repeat, repeat;
  }

  .gallery-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    gap: 2rem;
  }
  .gallery-header-left {}
  .gallery-headline {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: 0.01em;
    color: var(--ink);
  }
  .gallery-headline em { font-style: italic; color: var(--blush-dark); font-weight: 400; }
  .gallery-link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    white-space: nowrap;
    flex-shrink: 0;
    align-self: flex-end;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .gallery-link:hover { color: var(--blush-dark); border-color: var(--blush-dark); }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    grid-template-rows: 320px 240px;
    gap: 3px;
  }

  .gallery-cell {
    background-image: var(--texture-dots-light), linear-gradient(160deg, var(--ph-from), var(--ph-to));
    background-size: var(--texture-dots-light-size), cover;
    background-repeat: repeat, no-repeat;
    overflow: hidden;
    position: relative;
    cursor: pointer;
  }
  .gallery-cell img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .gallery-cell.large { grid-row: 1 / 3; }
  .gallery-cell.wide  { grid-column: 2 / 4; }

  .gallery-cell-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(38,24,32,0.55) 0%, rgba(155,74,101,0.35) 100%);
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .gallery-cell:hover .gallery-cell-overlay { opacity: 1; }

  .gallery-cell-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    transform: translateY(6px);
    transition: transform 0.4s ease;
  }
  .gallery-cell:hover .gallery-cell-label { transform: translateY(0); }

  /* ─── About Teaser ───────────────────────────────────── */
  .about-teaser { padding-block: var(--space-xl); background-color: var(--off-white); }
  .about-inner {
    display: grid; grid-template-columns: 1fr 1.15fr;
    gap: 5rem; align-items: center;
  }
  .about-placeholder {
    width: 100%; aspect-ratio: 3 / 4;
    background: linear-gradient(160deg, var(--blush-light), var(--blush-dark));
  }
  .about-content { display: flex; flex-direction: column; gap: 1.25rem; }
  .about-content h2 {
    font-family: var(--font-heading); font-size: var(--text-3xl);
    font-weight: 700; line-height: 1.2; color: var(--ink);
  }
  .about-body {
    font-family: var(--font-body); font-size: var(--text-base);
    font-weight: 300; color: #555; line-height: 1.75;
  }

  /* ─── Worries ───────────────────────────────────────── */
  .worries {
    padding-block: var(--space-xl);
    background-color: #fff;
    border-top: 1px solid var(--blush-light);
  }
  .worries-header { margin-bottom: 2rem; }
  .worries-header h2 {
    font-family: var(--font-heading); font-size: var(--text-4xl);
    color: var(--ink); line-height: 1.08;
  }
  .worries-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  .worry-card {
    padding: 1.5rem;
    border: 1px solid var(--blush-light);
    background-color: var(--off-white);
  }
  .worry-card h3 {
    font-family: var(--font-heading); font-size: var(--text-xl);
    color: var(--ink); margin-bottom: 0.75rem;
  }
  .worry-card p {
    font-family: var(--font-body); font-size: var(--text-sm);
    line-height: 1.7; color: #666;
  }

  /* ─── Final CTA ──────────────────────────────────────── */

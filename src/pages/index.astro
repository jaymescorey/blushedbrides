        </div>
        <a href="/services" class="lookbook-all reveal-child">View all services &rarr;</a>
      </div>

      <div class="lookbook-stage">

        <div class="lookbook-panel active" data-service="hair">
          <div class="lookbook-img-placeholder">
            <img src="/images/blushed-brides-bride-wedding-day-hair.jpg" alt="Bride wedding day hair" loading="lazy" />
          </div>
          <div class="lookbook-caption">
            <span class="lookbook-caption-kicker">Bride Focus</span>
            <h3>Bridal Hair</h3>
            <p>Updos, soft waves, braids, extensions — styled to last from first look to last dance.</p>
            <a href="/services#hair" class="service-link">Explore hair &rarr;</a>
          </div>
        </div>

        <div class="lookbook-panel" data-service="makeup">
          <div class="lookbook-img-placeholder">
            <img src="/images/blushed-brides-bride-glam-wedding-makeup.jpg" alt="Bride glam wedding makeup" loading="lazy" />
          </div>

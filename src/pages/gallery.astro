---
import BaseLayout from '../layouts/BaseLayout.astro';

// First batch — rendered server-side
const initialPhotos = [
  { src: '/images/blushed-brides-bridal-hair-updo-elegant.jpg',        alt: 'Elegant bridal hair updo',                       side: 'left',  size: 'tall'   },
  { src: '/images/blushed-brides-bridal-soft-glam-makeup-look.jpg',    alt: 'Soft glam bridal makeup look',                   side: 'right', size: 'tall'   },
  { src: '/images/blushed-brides-bridal-party-hair-styling.png',       alt: 'Bridal party hair styling',                      side: 'left',  size: 'wide'   },
  { src: '/images/blushed-brides-bridal-natural-makeup-look.png',      alt: 'Natural bridal makeup, warm tones',               side: 'right', size: 'square' },
  { src: '/images/blushed-brides-bridal-party-makeup-look.jpg',        alt: 'Bridal party makeup look',                       side: 'left',  size: 'square' },
  { src: '/images/blushed-brides-bridal-hair-updo-soft-waves.jpg',     alt: 'Bridal updo with soft waves',                    side: 'right', size: 'wide'   },
  { src: '/images/blushed-brides-bridal-makeup-artist-on-site.jpg',    alt: 'Bridal makeup artist on site',                   side: 'left',  size: 'tall'   },
  { src: '/images/blushed-brides-bride-getting-ready-soft-glam.jpg',   alt: 'Bride getting ready, soft glam',                 side: 'right', size: 'tall'   },
];

// Additional photos — appended client-side as user scrolls
const morePhotos = [
  { src: '/images/blushed-brides-bridal-updo-elegant-wedding-hair.jpg',  alt: 'Elegant wedding hair updo',                    side: 'left',  size: 'wide'   },
  { src: '/images/blushed-brides-bride-glam-wedding-makeup.jpg',         alt: 'Full glam bridal makeup',                      side: 'right', size: 'square' },
  { src: '/images/blushed-brides-wedding-morning-bridal-beauty.jpg',     alt: 'Wedding morning bridal beauty',                side: 'left',  size: 'square' },
  { src: '/images/blushed-brides-bridal-party-on-site-styling.png',      alt: 'Bridal party on-site styling',                 side: 'right', size: 'wide'   },
  { src: '/images/blushed-brides-bridal-updo-romantic-wedding-hair.png', alt: 'Romantic wedding hair updo',                   side: 'left',  size: 'tall'   },
  { src: '/images/blushed-brides-bride-airbrush-makeup-wedding.jpg',     alt: 'Bride airbrush makeup, wedding day',           side: 'right', size: 'tall'   },
  { src: '/images/blushed-brides-wedding-day-bridal-hair-styling.png',   alt: 'Wedding day bridal hair styling',              side: 'left',  size: 'wide'   },
  { src: '/images/blushed-brides-bridal-beauty-natural-look.jpg',        alt: 'Natural bridal beauty look',                   side: 'right', size: 'square' },
  { src: '/images/blushed-brides-on-location-bridal-beauty-prep.jpg',    alt: 'On-location bridal beauty prep',               side: 'left',  size: 'square' },
  { src: '/images/blushed-brides-bride-natural-glam-makeup.jpg',         alt: 'Bride natural glam makeup',                    side: 'right', size: 'wide'   },
  { src: '/images/blushed-brides-wedding-morning-hair-styling.jpg',      alt: 'Wedding morning hair styling',                 side: 'left',  size: 'tall'   },
  { src: '/images/blushed-brides-bride-wedding-day-glam-look.jpg',       alt: 'Bride wedding day glam look',                  side: 'right', size: 'tall'   },
];

const leftPhotos  = initialPhotos.filter(p => p.side === 'left');
const rightPhotos = initialPhotos.filter(p => p.side === 'right');

const galleryPageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ImageGallery',
      '@id': 'https://blushedbrides.com/gallery#gallery',
      name: 'Blushed Brides Bridal Hair and Makeup Gallery',
      url: 'https://blushedbrides.com/gallery',
      creator: {
        '@id': 'https://blushedbrides.com/#business',
      },
      about: {
        '@id': 'https://blushedbrides.com/#business',
      },
    },
    {
      '@type': 'CollectionPage',
      '@id': 'https://blushedbrides.com/gallery#webpage',
      url: 'https://blushedbrides.com/gallery',
      name: 'Gallery — Blushed Brides',
      isPartOf: {
        '@id': 'https://blushedbrides.com/#website',
      },
      about: {
        '@id': 'https://blushedbrides.com/#business',
      },
      mainEntity: {
        '@id': 'https://blushedbrides.com/gallery#gallery',
      },
    },
  ],
};
---

<BaseLayout
  title="Gallery — Blushed Brides"
  description="Browse our bridal hair and makeup portfolio. Soft, editorial, unforgettable looks for Northern California brides."
  canonicalUrl="https://blushedbrides.com/gallery"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(galleryPageSchema)} />
  </Fragment>

  <header class="site-header">
    <nav class="nav-inner">
      <a href="/" class="nav-logo">Blushed Brides</a>
      <ul class="nav-links">
        <li><a href="/services">Services</a></li>
        <li><a href="/gallery" class="active">Gallery</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/faq">FAQ</a></li>
        <li><a href="/book" class="nav-cta">Book Now</a></li>
      </ul>
    </nav>
  </header>

  <main>

    <!-- ─── Intro ──────────────────────────────────────────── -->
    <section class="gallery-intro">
      <p class="eyebrow">The Work</p>
      <h1>Every Look,<br><em>Remembered</em></h1>
    </section>

    <!-- ─── Two-column gallery ─────────────────────────────── -->
    <section class="gallery-columns">

      <div class="gallery-col gallery-col--left">
        {leftPhotos.map((photo, i) => (
          <figure
            class={`gallery-card from-left size-${photo.size}`}
            data-delay={i * 120}
            data-depth={0.72 + ((i % 3) * 0.18)}
          >
            <img
              src={photo.src}
              alt={photo.alt}
              loading={i === 0 ? 'eager' : 'lazy'}
              draggable="false"
            />
          </figure>
        ))}
      </div>

      <!-- Center spine (decorative) -->
      <div class="gallery-spine" aria-hidden="true">
        <div class="spine-line"></div>
        <div class="spine-dot"></div>
      </div>

      <div class="gallery-col gallery-col--right">
        {rightPhotos.map((photo, i) => (
          <figure
            class={`gallery-card from-right size-${photo.size}`}
            data-delay={i * 120 + 60}
            data-depth={0.82 + ((i % 3) * 0.2)}
          >
            <img
              src={photo.src}
              alt={photo.alt}
              loading={i === 0 ? 'eager' : 'lazy'}
              draggable="false"
            />
          </figure>
        ))}
      </div>

    </section>

    <!-- Pool of remaining photos for JS to append -->
    <script id="gallery-more-data" type="application/json" is:inline set:html={JSON.stringify(morePhotos)} />

    <!-- Load more -->
    <div id="gallery-load-more" class="gallery-load-more">
      <button id="gallery-load-btn" type="button">View More</button>
      <p id="gallery-count" class="gallery-count"></p>
    </div>

    <!-- ─── CTA ────────────────────────────────────────────── -->
    <section class="gallery-cta">
      <p class="eyebrow">Ready for yours?</p>
      <h2>Let's Create Something <em>Beautiful</em></h2>
      <a href="/book" class="btn-primary">Book a Consultation</a>
    </section>

    <!-- ─── Footer ─────────────────────────────────────────── -->
    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-brand">Blushed Brides</p>
        <p class="footer-sub">Bridal Hair &amp; Makeup · Northern California</p>
        <nav class="footer-nav">
          <a href="/services">Services</a>
          <a href="/gallery">Gallery</a>
          <a href="/about">About</a>
          <a href="/faq">FAQ</a>
          <a href="/book">Book</a>
          <a href="/careers">Join Our Team</a>
        </nav>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Blushed Brides. All rights reserved.</p>
      </div>
    </footer>

  </main>

</BaseLayout>

<script is:inline>
(function () {
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.documentElement.classList.add('gallery-animate');

  const cards = Array.from(document.querySelectorAll('.gallery-card'));

  const updateScrollMotion = () => {
    if (prefersReducedMotion) return;

    const viewHalf = window.innerHeight / 2;

    cards.forEach((card) => {
      if (!card.classList.contains('landed')) return;

      const rect = card.getBoundingClientRect();
      const cardCenter = rect.top + (rect.height / 2);
      const progress = (cardCenter - viewHalf) / viewHalf;
      const clamped = Math.max(-1, Math.min(1, progress));
      const depth = Number(card.dataset.depth || 1);

      card.style.setProperty('--drift-y', `${(-20 * clamped * depth).toFixed(2)}px`);
      card.style.setProperty('--drift-r', `${(-1.8 * clamped * depth).toFixed(2)}deg`);
      card.style.setProperty('--img-shift', `${(-12 * clamped * depth).toFixed(2)}px`);
    });
  };

  let ticking = false;
  const requestMotionUpdate = () => {
    if (ticking) return;
    ticking = true;
    window.requestAnimationFrame(() => {
      updateScrollMotion();
      ticking = false;
    });
  };

  window.addEventListener('scroll', requestMotionUpdate, { passive: true });
  window.addEventListener('resize', requestMotionUpdate);

  if (!('IntersectionObserver' in window)) {
    cards.forEach((card) => card.classList.add('landed'));
    requestMotionUpdate();
    return;
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const card  = entry.target;
      const delay = parseInt(card.dataset.delay ?? 0);
      setTimeout(() => {
        card.classList.add('landed');
        requestMotionUpdate();
      }, delay);
      observer.unobserve(card);
    });
  }, { threshold: 0.18, rootMargin: '0px 0px -8% 0px' });

  cards.forEach((c) => observer.observe(c));
  requestMotionUpdate();

  // ── Load more ─────────────────────────────────────────────
  const dataNode  = document.getElementById('gallery-more-data');
  let   moreData  = [];
  try {
    moreData = JSON.parse(dataNode?.textContent || '[]');
  } catch {
    moreData = [];
  }
  if (!Array.isArray(moreData)) moreData = [];

  const colLeft   = document.querySelector('.gallery-col--left');
  const colRight  = document.querySelector('.gallery-col--right');
  const loadMore  = document.getElementById('gallery-load-more');
  const loadBtn   = document.getElementById('gallery-load-btn');
  const countEl   = document.getElementById('gallery-count');
  const BATCH     = 6;
  let   pool      = [...moreData];
  let   loading   = false;
  let   leftCount  = document.querySelectorAll('.gallery-col--left .gallery-card').length;
  let   rightCount = document.querySelectorAll('.gallery-col--right .gallery-card').length;

  function updateCount() {
    if (!countEl) return;
    if (pool.length > 0) {
      countEl.textContent = `${pool.length} more to see`;
    } else {
      countEl.textContent = '';
    }
  }

  function makeCard(photo, side, staggerIndex) {
    const fig = document.createElement('figure');
    fig.className = `gallery-card from-${side} size-${photo.size}`;
    fig.dataset.delay = String(staggerIndex * 100);
    const depthBase = side === 'right' ? 0.82 : 0.72;
    const depthStep = side === 'right' ? 0.2  : 0.18;
    fig.dataset.depth = String(depthBase + ((staggerIndex % 3) * depthStep));

    const img = document.createElement('img');
    img.src       = photo.src;
    img.alt       = photo.alt;
    img.loading   = 'lazy';
    img.draggable = false;

    fig.appendChild(img);
    return fig;
  }

  function loadBatch() {
    if (loading || pool.length === 0) return;
    if (!colLeft || !colRight) return;

    loading = true;

    const batch = pool.splice(0, BATCH);
    const leftFragment  = document.createDocumentFragment();
    const rightFragment = document.createDocumentFragment();

    batch.forEach((photo) => {
      const side = photo.side;
      const idx  = side === 'left' ? leftCount++ : rightCount++;
      const card = makeCard(photo, side, idx);
      if (side === 'left') leftFragment.appendChild(card);
      else                 rightFragment.appendChild(card);
      observer.observe(card);
      cards.push(card);
    });

    colLeft.appendChild(leftFragment);
    colRight.appendChild(rightFragment);

    if (pool.length === 0 && loadMore) {
      loadMore.style.display = 'none';
    } else {
      updateCount();
    }

    loading = false;
  }

  if (loadBtn) {
    if (pool.length === 0) {
      loadMore.style.display = 'none';
    } else {
      updateCount();
      loadBtn.addEventListener('click', loadBatch);
    }
  }

})();
</script>

<style>
/* ─── Header ─────────────────────────────────────────────── */
.site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 1.25rem var(--gutter);
  transition: background 0.3s, backdrop-filter 0.3s;
}
.site-header--scrolled {
  background: rgba(250, 246, 242, 0.9);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(212, 137, 154, 0.15);
}
.nav-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-logo {
  font-family: var(--font-heading);
  font-size: var(--text-xl);
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--ink);
  text-decoration: none;
}
.nav-links {
  display: flex;
  gap: 2rem;
  list-style: none;
}
.nav-links a {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  opacity: 0.65;
  transition: opacity 0.2s;
}
.nav-links a:hover,
.nav-links a.active { opacity: 1; }
.nav-cta {
  background: var(--blush-dark);
  color: var(--off-white) !important;
  opacity: 1 !important;
  padding: 0.5rem 1.25rem;
  border-radius: 2px;
}

/* ─── Intro ──────────────────────────────────────────────── */
.gallery-intro {
  padding-top: calc(var(--space-2xl) + 2rem);
  padding-bottom: var(--space-lg);
  text-align: center;
  padding-left: var(--gutter);
  padding-right: var(--gutter);
}
.eyebrow {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--blush-dark);
  margin-bottom: 1rem;
}
.gallery-intro h1 {
  font-family: var(--font-heading);
  font-size: clamp(2.75rem, 6vw, 5rem);
  font-weight: 600;
  letter-spacing: 0.01em;
  color: var(--ink);
  line-height: 1.08;
}
.gallery-intro h1 em {
  font-style: italic;
  color: var(--blush-dark);
}

/* ─── Columns layout ─────────────────────────────────────── */
.gallery-columns {
  display: grid;
  grid-template-columns: 1fr 2px 1fr;
  gap: 0 clamp(1.5rem, 3vw, 3rem);
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 var(--gutter) var(--space-xl);
  align-items: start;
}

.gallery-col {
  display: flex;
  flex-direction: column;
  gap: clamp(2rem, 3.5vw, 3.25rem);
}

/* Offset right column down slightly for visual rhythm */
.gallery-col--right {
  margin-top: clamp(3rem, 6vw, 5rem);
}

/* ─── Center spine ───────────────────────────────────────── */
.gallery-spine {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 2rem;
}
.spine-line {
  width: 1px;
  height: 100%;
  min-height: 600px;
  background: linear-gradient(
    to bottom,
    transparent,
    var(--blush) 15%,
    var(--blush) 85%,
    transparent
  );
  opacity: 0.3;
}
.spine-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--blush);
  opacity: 0.5;
  margin-top: 0.75rem;
  flex-shrink: 0;
}

/* ─── Cards ──────────────────────────────────────────────── */
.gallery-card {
  --drift-y: 0px;
  --drift-r: 0deg;
  --img-shift: 0px;
  --lift-y: 0px;
  margin: 0;
  overflow: hidden;
  border-radius: 2px;
  background: var(--blush-light);
  box-shadow:
    0 8px 40px rgba(38, 24, 32, 0.12),
    0 2px 10px rgba(38, 24, 32, 0.07);
  opacity: 1;
  transform: translate3d(0, calc(var(--drift-y) + var(--lift-y)), 0) rotate(var(--drift-r));
  filter: blur(0);
  will-change: transform, opacity;
  transition:
    transform  0.9s cubic-bezier(0.22, 1, 0.36, 1),
    opacity    0.55s ease,
    filter     0.7s ease,
    box-shadow 0.35s ease;
}

/* Pre-animation state is only applied after JS initializes */
.gallery-animate .gallery-card:not(.landed) {
  opacity: 0;
  filter: blur(2px);
}

/* Left cards start off-screen left, tilted */
.gallery-animate .from-left:not(.landed) {
  transform: translate3d(-16vw, -88px, 0) rotate(-9deg) scale(0.985);
}

/* Right cards start off-screen right, tilted opposite */
.gallery-animate .from-right:not(.landed) {
  transform: translate3d(16vw, -88px, 0) rotate(9deg) scale(0.985);
}

/* Landed state */
.gallery-card.landed {
  opacity: 1;
  filter: blur(0);
}

/* Subtle hover lift */
.gallery-card:hover {
  --lift-y: -6px;
  box-shadow:
    0 20px 60px rgba(38, 24, 32, 0.18),
    0 6px 20px rgba(38, 24, 32, 0.1);
}

/* Size variants */
.size-tall   { aspect-ratio: 3 / 4; }
.size-wide   { aspect-ratio: 4 / 3; }
.size-square { aspect-ratio: 1 / 1; }

.gallery-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  /* Placeholder background until real images load */
  background: var(--blush-light);
  transform: translateY(var(--img-shift));
  transition: transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
}
.gallery-card:hover img {
  transform: translateY(calc(var(--img-shift) - 3px)) scale(1.04);
}

/* ─── CTA ────────────────────────────────────────────────── */
.gallery-cta {
  text-align: center;
  padding: var(--space-xl) var(--gutter);
  background-image:
    linear-gradient(to bottom, var(--off-white), var(--cream));
}
.gallery-cta h2 {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 600;
  letter-spacing: 0.01em;
  color: var(--ink);
  margin: 0.75rem 0 2rem;
  line-height: 1.1;
}
.gallery-cta h2 em {
  font-style: italic;
  color: var(--blush-dark);
}
.btn-primary {
  display: inline-block;
  background: var(--blush-dark);
  color: var(--off-white);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 0.9rem 2.5rem;
  border-radius: 2px;
  transition: background 0.2s, transform 0.2s;
}
.btn-primary:hover {
  background: var(--blush);
  transform: translateY(-1px);
}

/* ─── Footer ─────────────────────────────────────────────── */
.site-footer {
  background: var(--ink);
  border-top: 1px solid rgba(212, 137, 154, 0.15);
  padding: var(--space-xl) var(--gutter) var(--space-lg);
}
.footer-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  text-align: center;
}
.footer-brand {
  font-family: var(--font-heading);
  font-size: var(--text-2xl);
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--off-white);
  margin-bottom: 0.5rem;
}
.footer-sub {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--taupe);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: var(--space-md);
}
.footer-nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1.5rem;
  margin-bottom: var(--space-md);
}
.footer-nav a {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--taupe);
  text-decoration: none;
  transition: color 0.2s;
}
.footer-nav a:hover { color: var(--blush-light); }
.footer-copy {
  font-size: var(--text-xs);
  color: rgba(158, 144, 136, 0.5);
}

/* ─── Load more ─────────────────────────────────────────── */
.gallery-load-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  padding: var(--space-lg) var(--gutter) var(--space-xl);
}
#gallery-load-btn {
  background: transparent;
  border: 1px solid var(--blush-dark);
  color: var(--blush-dark);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.75rem 2.25rem;
  border-radius: 2px;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, transform 0.2s;
}
#gallery-load-btn:hover {
  background: var(--blush-dark);
  color: var(--off-white);
  transform: translateY(-1px);
}
.gallery-count {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--taupe);
  opacity: 0.7;
}

/* ─── Responsive ─────────────────────────────────────────── */
@media (max-width: 640px) {
  .gallery-columns {
    grid-template-columns: 1fr;
  }
  .gallery-spine { display: none; }
  .gallery-col--right { margin-top: 0; }
  .gallery-animate .from-left:not(.landed)  { transform: translate3d(-22vw, -50px, 0) rotate(-5deg); }
  .gallery-animate .from-right:not(.landed) { transform: translate3d(22vw, -50px, 0) rotate(5deg); }
}

@media (prefers-reduced-motion: reduce) {
  .gallery-card,
  .gallery-card img {
    transition: none;
    transform: none;
  }
  .gallery-animate .gallery-card:not(.landed) {
    opacity: 1;
    filter: none;
  }
}
</style>
